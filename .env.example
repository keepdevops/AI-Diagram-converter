# Copy to .env and adjust. Defaults target plantuml-server (the validated engine).

# Host port the editor is served on.
WEB_PORT=8088

# --- Render module -------------------------------------------------------
# Three interchangeable topologies for PlantUML rendering:
#   server (this file)  external render container (plantuml-server or kroki)
#   bridge              jar runs inside the bridge container (-picoweb + graphviz);
#                       no render image. Use the bridge override:
#                         docker compose -f docker-compose.yml \
#                           -f docker-compose.bridge.yml up -d
# (A client/in-browser PlantUML module was evaluated and descoped: the official
#  plantuml.js is PNG-only + heavy WASM. Mermaid already renders client-side.)
# Mermaid always renders client-side regardless of this choice.
#
# VITE_MERMAID_SECURITY (frontend build arg): mermaid securityLevel, default
# 'strict'. Set to 'loose' to allow HTML labels / clickable nodes (trusted use).
#
# Default: official PlantUML server (Jetty). The `server` validator is verified
# against this engine (and, via picoweb, the bridge module reuses it unchanged).
RENDER_IMAGE=plantuml/plantuml-server:jetty
RENDER_PROXY_PASS=http://render:8080/
PLANTUML_SERVER=http://render:8080

# Alternative: Kroki (one service, many diagram formats). NOTE: the bridge
# validation adapter for Kroki lands in Sprint 2 — preview works, but AI Fix
# may not validate against Kroki yet.
# RENDER_IMAGE=yuzutech/kroki
# RENDER_PROXY_PASS=http://render:8000
# PLANTUML_SERVER=http://render:8000/plantuml

# Renderer module (Sprint 1 ships `server`; bridge/client added later).
PLANTUML_RENDERER=server

# --- LLM (optional, --profile llm) --------------------------------------
MATRIX_SAFE_URL=http://matrix-safe:8765
MATRIX_SAFE_IMAGE=matrix-safe:local
DIAGRAM_AGENT=local-coder-14b.json
# Directory holding the model weights, mounted read-only into matrix-safe.
MODEL_DIR=./models
